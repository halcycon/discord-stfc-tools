# Environment Variables Template
# Copy this to .env and fill in your actual values

# D1 database (create with: wrangler d1 create stfc-db)
D1_DATABASE_NAME=stfc-db
D1_DATABASE_ID=your-d1-database-id-here

# KV Namespace IDs (optional — coordinate lookup uses bundled systemData.ts)
KV_NAMESPACE_ID=your-production-namespace-id-here
KV_NAMESPACE_PREVIEW_ID=your-preview-namespace-id-here

# Optional. Custom Worker CPU limit (Paid plans only).
# Leave unset on the Free plan.
CPU_MS=

# Discord Configuration (Discord Developer Portal)
DISCORD_APPLICATION_ID=your-discord-application-id-here
DISCORD_PUBLIC_KEY=your-discord-public-key-here
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Cloudflare Worker script name (wrangler.json "name"). Default: stfc-tools.
# Set explicitly if you already deployed under a different name — changing it
# creates a NEW worker on the next deploy (old name keeps its DO state/secrets).
# WORKER_NAME=stfc-tools

# Public URL of the deployed worker (usually matches WORKER_NAME)
WORKER_URL=https://stfc-tools.your-subdomain.workers.dev

# Cloudflare Workers plan (affects /alliance suggest Approve-all chunking)
# Same Continue flow on both plans — only chunk size changes.
# free  = default; 2 links per Approve-all / Continue click (50 subrequest limit)
# paid  = 6 links per click (under ~10/interaction waitUntil cliff); enables cpu_ms=300000
# WORKERS_PLAN=free
# Optional override (1–10 max): ALLIANCE_APPROVE_CHUNK=1

# Admin web UI (Cloudflare Pages) — Discord OAuth
# Create OAuth2 redirect: {WORKER_URL}/api/admin/auth/callback
# DISCORD_CLIENT_ID defaults to DISCORD_APPLICATION_ID if unset
# DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
ADMIN_SESSION_SECRET=generate-a-long-random-string
# Comma-separated Pages + local origins (CORS + post-login redirect)
ADMIN_WEB_ORIGIN=http://localhost:5173

# Cloudflare Pages project name for admin-web (npm run admin-web:push-env / admin-web:deploy)
ADMIN_WEB_PAGES_PROJECT=stfc-tools-admin

# R2 bucket for archived verification screenshots (optional)
R2_BUCKET_NAME=stfc-verification-assets

# Optional Workers AI for DM intent assist (OFF by default — avoid surprise charges)
# ENABLE_WORKERS_AI=true          # adds AI binding to wrangler.json
# DM_AI_ENABLED=true              # global runtime allow
# DM_AI_DAILY_LIMIT=50            # hard-stop AI calls per UTC day (D1 counter)

# Push .env to Cloudflare (secrets + regenerate wrangler.json):
#   npm run push-env
#
# Or set secrets manually:
#   npx wrangler secret put DISCORD_PUBLIC_KEY
#   npx wrangler secret put DISCORD_BOT_TOKEN
#
# Enable privileged intents in Discord Developer Portal:
#   - Server Members Intent (GUILD_MEMBER_ADD + member poll fallback)
#   - Message Content Intent (read verification DMs via Gateway)
#
# Gateway runs in a Durable Object (DISCORD_GATEWAY binding) — deploy applies migration v1 automatically.
