# Production Pages: set to your Worker URL (no trailing slash)
# VITE_API_BASE_URL=https://stfc-tools.your-subdomain.workers.dev

# Local: point at wrangler dev so OAuth session cookies work on the API origin
VITE_API_BASE_URL=http://127.0.0.1:8787

# Legal pages (Privacy / Terms) — set in Cloudflare Pages env, NOT in git.
# Values are baked into the static build at `npm run build`.
# VITE_LEGAL_PRODUCT_NAME=STFC Tools
# VITE_LEGAL_LEGAL_NAME=Your Name or Company Ltd
# VITE_LEGAL_CONTACT=privacy@example.com
# VITE_LEGAL_ADDRESS=Optional postal address
# VITE_LEGAL_GOVERNING_LAW=England and Wales
# VITE_LEGAL_VENUE=London, England
# VITE_LEGAL_LIABILITY_CAP=£0
# VITE_LEGAL_EFFECTIVE_DATE=15 July 2026
# VITE_LEGAL_VERSION=1.1
