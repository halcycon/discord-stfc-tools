{
	"name": "stfc-tools",
	"version": "1.10.4",
	"description": "STFC Discord bot — verification, alliance management, coordinate lookup, and tables.",
	"private": true,
	"scripts": {
		"deploy": "npm run generate-config && wrangler deploy",
		"dev": "npm run generate-config && wrangler dev",
		"start": "npm run generate-config && wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"build": "npm run generate-config && tsc && wrangler deploy --dry-run",
		"docker:build": "docker build -t stfc-tools .",
		"docker:run": "docker-compose up",
		"generate-config": "node generate-config.js",
		"push-env": "node scripts/push-env.js",
		"migrate-kv": "node migrate-to-kv.js",
		"register-commands": "node register-command.js",
		"db:migrate": "node scripts/db-migrate.js",
		"db:migrate-local": "node scripts/db-migrate.js --local",
		"admin-web:dev": "npm run dev --prefix admin-web",
		"admin-web:build": "npm run build --prefix admin-web",
		"admin-web:push-env": "node scripts/push-admin-web-env.js",
		"admin-web:deploy": "node scripts/deploy-admin-web.js",
		"kv:create": "wrangler kv namespace create SYSTEM_DATA",
		"kv:create-preview": "wrangler kv namespace create SYSTEM_DATA --preview",
		"kv:upload": "wrangler kv bulk put --binding SYSTEM_DATA --preview false kv-bulk-upload.json",
		"kv:upload-preview": "wrangler kv bulk put --binding SYSTEM_DATA --preview kv-bulk-upload.json"
	},
	"dependencies": {
		"discord-interactions": "^3.4.0",
		"pako": "^3.0.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.19",
		"@cloudflare/workers-types": "^4.20241106.0",
		"@types/node": "^22.10.2",
		"@types/pako": "^2.0.4",
		"dotenv": "^17.2.1",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.26.1"
	},
	"keywords": [
		"discord",
		"bot",
		"stfc",
		"star-trek-fleet-command",
		"cloudflare-workers",
		"typescript"
	],
	"author": "",
	"license": "MIT"
}
